generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntrySource {
  MANUAL
  UPLOAD
}

model User {
  id        String   @id @db.Uuid
  email     String?  @unique
  createdAt DateTime @default(now())

  entries Entry[]
  uploads Upload[]

  @@index([createdAt])
}

model Entry {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid
  source    EntrySource @default(MANUAL)
  rawText   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentences    Sentence[]
  triggers     TriggerRank[]
  reflections  Reflection[]
  analysis     Analysis?
  uploads      Upload[]

  @@index([userId, createdAt(sort: Desc)])
}

model Sentence {
  id       String @id @default(uuid()) @db.Uuid
  entryId  String @db.Uuid
  entry    Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  position       Int
  text           String
  sentimentScore Int

  @@unique([entryId, position])
  @@index([entryId])
}

model TriggerRank {
  id      String @id @default(uuid()) @db.Uuid
  entryId String @db.Uuid
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  rank  Int
  word  String
  count Int

  @@unique([entryId, rank])
  @@index([entryId, word])
}

model Analysis {
  id        String @id @default(uuid()) @db.Uuid
  entryId   String @db.Uuid @unique
  entry     Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  summary   String

  createdAt DateTime @default(now())

  @@index([entryId])
}

model Reflection {
  id       String @id @default(uuid()) @db.Uuid
  entryId  String @db.Uuid
  entry    Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  index Int
  text  String

  @@unique([entryId, index])
  @@index([entryId])
}

model Upload {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @db.Uuid

  originalFilename String
  byteSize         Int
  mimeType         String?

  createdAt DateTime @default(now())

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryId String? @db.Uuid
  entry   Entry?  @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

