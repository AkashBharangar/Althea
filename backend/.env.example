# Port Render assigns automatically — PORT is injected on Render; optional locally.
PORT=8787
NODE_ENV=development

# Browser origins allowed to call this API (comma-separated, no spaces after commas is fine).
# Production example:
# CLIENT_ORIGIN=https://althea.vercel.app,https://www.yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# Set to 1 to allow any https://*.vercel.app origin (preview deployments).
# Turn off in production if you only want your production URL in CLIENT_ORIGIN.
# ALLOW_VERCEL_PREVIEWS=1

# Neon Postgres connection string used by Prisma.
# Example:
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Supabase project URL and anon key used to verify the incoming user JWT.
# Example:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Rate limiter defaults (window in ms, max requests in window).
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200
