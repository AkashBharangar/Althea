# Port Render assigns automatically — PORT is injected on Render; optional locally.
PORT=8787

# Browser origins allowed to call this API (comma-separated, no spaces after commas is fine).
# Production example:
# CLIENT_ORIGIN=https://althea.vercel.app,https://www.yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# Set to 1 to allow any https://*.vercel.app origin (preview deployments).
# Turn off in production if you only want your production URL in CLIENT_ORIGIN.
# ALLOW_VERCEL_PREVIEWS=1
